@model ClientVM
@{
    ViewData["Title"] = "Delete Client";
}

<style>
    .aurum-page-header {
        margin-bottom: 2rem;
    }

        .aurum-page-header .page-eyebrow {
            font-size: 0.65rem;
            font-weight: 600;
            letter-spacing: 0.22em;
            text-transform: uppercase;
            color: #c0392b;
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 6px;
        }

            .aurum-page-header .page-eyebrow::before,
            .aurum-page-header .page-eyebrow::after {
                content: '';
                display: inline-block;
                height: 1px;
                width: 28px;
                background: #c0392b;
                opacity: 0.4;
            }

        .aurum-page-header h1 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2.2rem;
            font-weight: 700;
            color: var(--maroon-dark);
            letter-spacing: 0.03em;
            line-height: 1.1;
        }

    .aurum-card {
        background: #fff;
        border: 1px solid rgba(201,168,76,0.18);
        border-top: 3px solid var(--gold);
        border-radius: 4px;
        padding: 2rem 2.2rem;
        box-shadow: 0 4px 24px rgba(74,15,28,0.07);
    }

        /* Delete card gets red top accent */
        .aurum-card.danger-card {
            border-top-color: #c0392b;
        }

    .aurum-card-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.35rem;
        font-weight: 600;
        color: var(--maroon);
        letter-spacing: 0.04em;
        margin-bottom: 1.4rem;
        padding-bottom: 0.7rem;
        border-bottom: 1px solid rgba(201,168,76,0.2);
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .aurum-card-title::before {
            content: '';
            display: inline-block;
            width: 4px;
            height: 20px;
            background: var(--gold);
            border-radius: 2px;
        }

    .danger-card .aurum-card-title::before {
        background: #c0392b;
    }

    .aurum-label {
        font-size: 0.68rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--text-mid);
        padding-top: 8px;
    }

    /* Read-only fields on delete are visually muted */
    .aurum-input {
        background: #f5f0f0;
        border: 1px solid rgba(107,26,42,0.12);
        border-radius: 2px;
        font-size: 0.85rem;
        color: var(--text-mid);
        padding: 8px 12px;
        width: 100%;
        pointer-events: none;
    }

        .aurum-input[type="file"] {
            padding: 5px 10px;
        }

    .aurum-checkbox-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
        padding-top: 6px;
    }

    .aurum-checkbox {
        width: 16px;
        height: 16px;
        accent-color: var(--maroon);
    }

    .aurum-checkbox-label {
        font-size: 0.8rem;
        color: var(--text-mid);
    }

    /* Danger confirm banner */
    .delete-warning {
        background: rgba(192,57,43,0.06);
        border: 1px solid rgba(192,57,43,0.25);
        border-left: 4px solid #c0392b;
        border-radius: 3px;
        padding: 12px 16px;
        margin-bottom: 1.5rem;
        font-size: 0.78rem;
        color: #7b1a1a;
        letter-spacing: 0.02em;
        display: flex;
        align-items: flex-start;
        gap: 10px;
    }

        .delete-warning::before {
            content: '⚠';
            font-size: 1rem;
            flex-shrink: 0;
            margin-top: 1px;
        }

    /* Buttons */
    .btn-aurum-danger {
        background: linear-gradient(135deg, #922b21 0%, #c0392b 100%);
        color: #fff !important;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        padding: 10px 28px;
        border: none;
        border-radius: 2px;
        box-shadow: 0 2px 12px rgba(192,57,43,0.3);
        transition: box-shadow 0.25s, transform 0.2s;
        cursor: pointer;
    }

        .btn-aurum-danger:hover {
            box-shadow: 0 4px 20px rgba(192,57,43,0.45);
            transform: translateY(-1px);
        }

    .btn-aurum-outline {
        background: transparent;
        border: 1px solid var(--gold);
        color: var(--gold) !important;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        padding: 7px 18px;
        border-radius: 2px;
        transition: background 0.2s, color 0.2s;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
    }

        .btn-aurum-outline:hover {
            background: var(--gold);
            color: var(--maroon-dark) !important;
        }

    .aurum-back-link {
        font-size: 0.68rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--maroon);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 1.5rem;
        opacity: 0.7;
        transition: opacity 0.2s;
    }

        .aurum-back-link:hover {
            opacity: 1;
            color: var(--maroon);
        }

        .aurum-back-link::before {
            content: '←';
            font-size: 0.9rem;
        }
</style>

<a class="aurum-back-link" asp-controller="Clients" asp-action="Index">Back to Clients</a>

<div class="aurum-page-header">
    <div class="page-eyebrow">Confirm Deletion</div>
    <h1>Remove Client Record</h1>
</div>

<form id="frmCreate"
      asp-action="Delete"
      asp-controller="Clients">

    <input type="hidden" asp-for="ClientId" />
    <input type="hidden" asp-for="Image" />

    <div class="row g-4">

        <!-- ── Left: Client Preview ── -->
        <div class="col-lg-6">
            <div class="aurum-card danger-card">
                <div class="aurum-card-title">Client Record</div>

                <div class="delete-warning">
                    This action is permanent. The following client and all associated data will be removed and cannot be recovered.
                </div>

                <!-- Client Name -->
                <div class="row mb-3 align-items-start">
                    <label class="aurum-label col-4" asp-for="ClientName"></label>
                    <div class="col-8">
                        <input asp-for="ClientName" class="aurum-input" readonly />
                    </div>
                </div>

                <!-- Birth Date -->
                <div class="row mb-3 align-items-start">
                    <label class="aurum-label col-4" asp-for="BirthDate"></label>
                    <div class="col-8">
                        <input asp-for="BirthDate" class="aurum-input" type="date" readonly />
                    </div>
                </div>

                <!-- Age -->
                <div class="row mb-3 align-items-start">
                    <label class="aurum-label col-4" asp-for="Age"></label>
                    <div class="col-8">
                        <input asp-for="Age" class="aurum-input" readonly />
                    </div>
                </div>

                <!-- Photo -->
                <div class="row mb-3 align-items-start">
                    <label class="aurum-label col-4" asp-for="ImageFile"></label>
                    <div class="col-8">
                        @if (!string.IsNullOrEmpty(Model.Image))
                        {
                            <img src="@Model.Image" alt="Client photo"
                                 style="width:60px;height:60px;object-fit:cover;border-radius:2px;border:1px solid rgba(192,57,43,0.25);opacity:0.75;" />
                        }
                        else
                        {
                            <span style="font-size:0.75rem;color:rgba(90,58,58,0.5);font-style:italic;">No photo on file</span>
                        }
                    </div>
                </div>

                <!-- Marital Status -->
                <div class="row mb-4 align-items-start">
                    <label class="aurum-label col-4" asp-for="MaritalStatus"></label>
                    <div class="col-8">
                        <div class="aurum-checkbox-wrap">
                            <input asp-for="MaritalStatus" class="aurum-checkbox" type="checkbox" id="maritalCheck" disabled />
                            <label class="aurum-checkbox-label" for="maritalCheck">Married</label>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="d-flex gap-3 pt-2" style="border-top:1px solid rgba(192,57,43,0.15);">
                    <button type="submit" class="btn-aurum-danger">Confirm Delete</button>
                    <a class="btn-aurum-outline" asp-controller="Clients" asp-action="Index">Cancel</a>
                </div>
            </div>
        </div>

        <!-- ── Right: Linked Events ── -->
        <div class="col-lg-6">
            <div class="aurum-card">
                <div class="aurum-card-title">Linked Events</div>
                <p style="font-size:0.75rem;color:var(--text-mid);margin-bottom:1rem;">
                    The following events are associated with this client and will also be affected.
                </p>
                <div id="eventContainer">
                    @foreach (var item in Model.EventList)
                    {
                        <script>LoadData(@item)</script>
                    }
                </div>
            </div>
        </div>

    </div>
</form>
