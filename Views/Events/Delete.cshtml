@model EventManagementCore.Models.Event

@{
    ViewData["Title"] = "Remove Event Type";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            <div class="aurum-page-header text-center">
                <div class="page-eyebrow danger">Irreversible Action</div>
                <h1>Delete <span>@Model.EventName</span></h1>
            </div>

            <div class="aurum-card border-danger-soft">
                <div class="card-accent-danger"></div>

                <div class="p-4">
                    <div class="warning-banner mb-4">
                        <i class="bi bi-exclamation-triangle"></i>
                        <span>Are you sure you want to remove this event type from the catalog?</span>
                    </div>

                    <div class="details-section mb-5">
                        <span class="aurum-label">Event Specification</span>
                        <div class="display-value">@Html.DisplayFor(model => model.EventName)</div>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="EventId" />

                        <div class="d-flex flex-column gap-3">
                            <button type="submit" class="btn-aurum-danger w-100">
                                Confirm Deletion
                            </button>
                            <a asp-action="Index" class="btn-aurum-outline text-center w-100">
                                Cancel & Return
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <p class="text-center mt-4 small text-muted italic" style="font-family: 'Cormorant Garamond', serif;">
                "Carefully managing every aspect of the legacy."
            </p>
        </div>
    </div>
</div>

<style>
    /* ── Header Styles ── */
    .aurum-page-header {
        margin-bottom: 2.5rem;
    }

        .aurum-page-header .page-eyebrow.danger {
            font-family: 'Montserrat', sans-serif;
            font-size: 0.65rem;
            font-weight: 600;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: #c0392b; /* Danger Red */
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            margin-bottom: 8px;
        }

            .aurum-page-header .page-eyebrow.danger::before,
            .aurum-page-header .page-eyebrow.danger::after {
                content: '';
                display: inline-block;
                height: 1px;
                width: 30px;
                background: #c0392b;
                opacity: 0.4;
            }

        .aurum-page-header h1 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--maroon-dark);
            margin: 0;
        }

            .aurum-page-header h1 span {
                font-weight: 300;
                font-style: italic;
                color: #c0392b;
            }

    /* ── Card Styling ── */
    .aurum-card {
        background: white;
        border: 1px solid rgba(192, 57, 43, 0.1);
        box-shadow: 0 10px 30px rgba(192, 57, 43, 0.08);
        position: relative;
        overflow: hidden;
    }

    .card-accent-danger {
        height: 4px;
        background: linear-gradient(90deg, #c0392b, #e74c3c, #c0392b);
    }

    .warning-banner {
        background-color: #fdf2f2;
        border-left: 3px solid #c0392b;
        padding: 12px 15px;
        color: #a93226;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.8rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    /* ── Data Display ── */
    .aurum-label {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--maroon-mid);
        margin-bottom: 5px;
        display: block;
    }

    .display-value {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.8rem;
        color: var(--maroon-dark);
        border-bottom: 1px solid var(--off-white);
        padding-bottom: 10px;
    }

    /* ── Buttons ── */
    .btn-aurum-danger {
        background: linear-gradient(135deg, #c0392b, #a93226);
        color: white;
        border: none;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 2px;
        padding: 14px;
        transition: 0.3s;
    }

        .btn-aurum-danger:hover {
            filter: brightness(1.2);
            letter-spacing: 3px;
            box-shadow: 0 5px 15px rgba(192, 57, 43, 0.3);
        }

    .btn-aurum-outline {
        background: transparent;
        color: var(--maroon);
        border: 1px solid var(--gold);
        font-family: 'Montserrat', sans-serif;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        padding: 12px;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-aurum-outline:hover {
            background: var(--gold-pale);
            color: var(--maroon-dark);
        }

    .italic {
        font-style: italic;
    }
</style>