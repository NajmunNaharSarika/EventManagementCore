@{
    ViewData["Title"] = "Dashboard - Aurum Events";
}

<div class="container-fluid py-4 px-md-4">

    <div class="aurum-hero text-center mb-5 pb-3">
        <div class="page-eyebrow">Command Center</div>
        <h1 class="hero-title">Crafting <span>Extraordinary</span> Experiences</h1>
        <p class="hero-subtitle">Welcome back. Manage your elite clientele and upcoming celebrations.</p>

        <div class="d-flex justify-content-center gap-3 mt-4">
            <a asp-controller="Clients" asp-action="Create" class="btn-aurum-primary">
                + Register Client
            </a>
            <a asp-controller="Events" asp-action="Create" class="btn-aurum-outline">
                Define Event Type
            </a>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="aurum-stat-card">
                <div class="card-accent"></div>
                <div class="stat-content">
                    <span class="stat-label">Total Clients</span>
                    <h2 class="stat-value">4500+</h2>
                </div>
                <div class="stat-icon">✦</div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="aurum-stat-card">
                <div class="card-accent"></div>
                <div class="stat-content">
                    <span class="stat-label">Active Event Types</span>
                    <h2 class="stat-value">23+</h2>
                </div>
                <div class="stat-icon">✧</div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="aurum-stat-card">
                <div class="card-accent"></div>
                <div class="stat-content">
                    <span class="stat-label">System Users</span>
                    <h2 class="stat-value">370+</h2>
                </div>
                <div class="stat-icon">✦</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="aurum-card h-100">
                <div class="card-accent"></div>
                <div class="p-4 p-md-5">
                    <h3 class="section-title">System Modules</h3>
                    <p class="text-muted small mb-4" style="font-family: 'Montserrat', sans-serif;">Select an area to manage your business operations.</p>

                    <div class="module-grid">
                        <a asp-controller="Clients" asp-action="Index" class="module-card">
                            <h4 class="module-title">Client Registry</h4>
                            <p class="module-desc">Manage profiles, contact details, and view booked events for your clients.</p>
                            <span class="module-link-text">Access Registry →</span>
                        </a>

                        <a asp-controller="Events" asp-action="Index" class="module-card">
                            <h4 class="module-title">Event Catalog</h4>
                            <p class="module-desc">Configure the types of luxury services and celebrations offered.</p>
                            <span class="module-link-text">Access Catalog →</span>
                        </a>

                        <a asp-controller="Role" asp-action="Index" class="module-card">
                            <h4 class="module-title">Access Control</h4>
                            <p class="module-desc">Manage staff roles, permissions, and assign users to specific designations.</p>
                            <span class="module-link-text">Manage Access →</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="aurum-card vision-card h-100">
                <div class="vision-content text-center">
                    <span class="brand-ornament-large mb-4"></span>
                    <h4 class="vision-quote">"Luxury is in each detail."</h4>
                    <p class="vision-author">- Aurum Events & Co.</p>
                    <div class="vision-divider my-4"></div>
                    <p class="vision-text">System Version 1.0<br>Authorized Personnel Only</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* ── Hero Section ── */
    .aurum-hero {
        padding-top: 2rem;
    }

    .page-eyebrow {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.65rem;
        font-weight: 600;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 20px;
        margin-bottom: 15px;
    }

        .page-eyebrow::before, .page-eyebrow::after {
            content: '';
            display: inline-block;
            height: 1px;
            width: 50px;
            background: var(--gold);
            opacity: 0.4;
        }

    .hero-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 3.5rem;
        font-weight: 700;
        color: var(--maroon-dark);
        margin: 0 0 10px 0;
        line-height: 1.1;
    }

        .hero-title span {
            font-weight: 300;
            font-style: italic;
            color: var(--gold);
        }

    .hero-subtitle {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.9rem;
        color: var(--text-mid);
        letter-spacing: 0.05em;
    }

    /* ── Stat Cards ── */
    .aurum-stat-card {
        background: white;
        border: 1px solid rgba(201, 168, 76, 0.15);
        box-shadow: 0 8px 25px rgba(74, 15, 28, 0.05);
        padding: 25px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
        overflow: hidden;
        transition: transform 0.3s;
    }

        .aurum-stat-card:hover {
            transform: translateY(-5px);
        }

    .card-accent {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, var(--maroon), var(--gold), var(--maroon));
    }

    .stat-label {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.65rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--maroon-mid);
        display: block;
        margin-bottom: 5px;
    }

    .stat-value {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--maroon-dark);
        margin: 0;
        line-height: 1;
    }

    .stat-icon {
        font-size: 2.5rem;
        color: var(--gold-pale);
        line-height: 1;
    }

    /* ── Modules Section ── */
    .aurum-card {
        background: white;
        border: 1px solid rgba(201, 168, 76, 0.15);
        box-shadow: 0 10px 30px rgba(74, 15, 28, 0.06);
        position: relative;
    }

    .section-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2rem;
        color: var(--maroon-dark);
        border-bottom: 1px solid var(--gold-pale);
        padding-bottom: 10px;
        margin-bottom: 10px;
    }

    .module-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 15px;
        margin-top: 20px;
    }

    .module-card {
        display: block;
        padding: 20px;
        border: 1px solid #f0f0f0;
        text-decoration: none;
        background: var(--off-white);
        transition: all 0.3s;
    }

        .module-card:hover {
            background: white;
            border-color: var(--gold);
            box-shadow: 0 5px 15px rgba(201, 168, 76, 0.15);
        }

    .module-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.4rem;
        font-weight: 600;
        color: var(--maroon);
        margin-bottom: 8px;
    }

    .module-desc {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.8rem;
        color: var(--text-mid);
        margin-bottom: 12px;
    }

    .module-link-text {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--gold);
        transition: color 0.2s;
    }

    .module-card:hover .module-link-text {
        color: var(--maroon);
    }

    /* ── Vision / Notice Card ── */
    .vision-card {
        background: linear-gradient(135deg, var(--maroon-dark), var(--maroon));
        border: none;
        color: var(--gold-pale);
    }

    .vision-content {
        padding: 40px 30px;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

    .brand-ornament-large {
        display: inline-block;
        width: 40px;
        height: 2px;
        background: var(--gold);
    }

    .vision-quote {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2rem;
        font-style: italic;
        color: var(--gold);
        line-height: 1.2;
        margin-bottom: 10px;
    }

    .vision-author {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: var(--gold-light);
        opacity: 0.8;
    }

    .vision-divider {
        width: 100%;
        height: 1px;
        background: rgba(201, 168, 76, 0.3);
    }

    .vision-text {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.7rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(245, 233, 204, 0.6);
        line-height: 1.8;
    }

    /* ── Buttons ── */
    .btn-aurum-primary {
        background: linear-gradient(135deg, var(--maroon-dark), var(--maroon));
        color: var(--gold-pale);
        border: none;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        padding: 14px 28px;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-aurum-primary:hover {
            filter: brightness(1.2);
            color: white;
            box-shadow: 0 5px 15px rgba(74, 15, 28, 0.2);
        }

    .btn-aurum-outline {
        background: transparent;
        color: var(--maroon);
        border: 1px solid var(--gold);
        font-family: 'Montserrat', sans-serif;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        padding: 13px 28px;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-aurum-outline:hover {
            background: var(--gold-pale);
            color: var(--maroon-dark);
        }

    
</style>