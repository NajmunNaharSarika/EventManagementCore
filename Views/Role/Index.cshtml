@{
    ViewData["Title"] = "Role Management";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">

            <div class="aurum-page-header text-center">
                <div class="page-eyebrow">Access Control</div>
                <h1>Role <span>Management</span></h1>
            </div>

            @if (ViewBag.msg != null)
            {
                <div class="aurum-toast mb-4">
                    <i class="bi bi-check2-circle"></i>
                    <span>@ViewBag.msg</span>
                </div>
            }

            <div class="aurum-card">
                <div class="card-accent"></div>

                <div class="p-4 p-md-5">
                    <form asp-action="CreateRole" asp-controller="Role" method="post">
                        <div class="aurum-form-group">
                            <label class="aurum-label">Authority Designation</label>
                            <p class="text-muted small mb-4 italic" style="font-family: 'Cormorant Garamond', serif; font-size: 1rem;">
                                Enter the name of the new administrative or operational role to be established.
                            </p>

                            <div class="row g-3">
                                <div class="col-md-8">
                                    <div class="input-wrapper">
                                        <input type="text" name="userRole" class="aurum-input" placeholder="e.g. Coordinator, Administrator..." required />
                                        <span class="input-focus-line"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <button type="submit" class="btn-aurum-primary w-100 h-100">
                                        Create Role
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <p class="text-center mt-5 small text-muted italic" style="font-family: 'Cormorant Garamond', serif; font-size: 1.1rem;">
                "Preserving the integrity of the legacy through structured access."
            </p>
        </div>
    </div>
</div>

<style>
    /* ── Header Styles ── */
    .aurum-page-header {
        margin-bottom: 3rem;
    }

        .aurum-page-header .page-eyebrow {
            font-family: 'Montserrat', sans-serif;
            font-size: 0.65rem;
            font-weight: 600;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: var(--gold);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 20px;
            margin-bottom: 10px;
        }

            .aurum-page-header .page-eyebrow::before,
            .aurum-page-header .page-eyebrow::after {
                content: '';
                display: inline-block;
                height: 1px;
                width: 40px;
                background: var(--gold);
                opacity: 0.4;
            }

        .aurum-page-header h1 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 3rem;
            font-weight: 700;
            color: var(--maroon-dark);
            margin: 0;
            line-height: 1;
        }

            .aurum-page-header h1 span {
                font-weight: 300;
                font-style: italic;
                color: var(--gold);
            }

    /* ── Feedback Message ── */
    .aurum-toast {
        background: var(--off-white);
        border: 1px solid var(--gold-pale);
        border-left: 4px solid #27ae60;
        padding: 15px 20px;
        color: var(--maroon-dark);
        font-family: 'Montserrat', sans-serif;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
    }

        .aurum-toast i {
            color: #27ae60;
            font-size: 1.2rem;
        }

    /* ── Card Styling ── */
    .aurum-card {
        background: white;
        border: 1px solid rgba(201, 168, 76, 0.15);
        box-shadow: 0 15px 40px rgba(74, 15, 28, 0.07);
        position: relative;
        overflow: hidden;
    }

    .card-accent {
        height: 5px;
        background: linear-gradient(90deg, var(--maroon-dark), var(--gold), var(--maroon-dark));
    }

    /* ── Form Controls ── */
    .aurum-label {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--maroon-mid);
        margin-bottom: 5px;
        display: block;
    }

    .input-wrapper {
        position: relative;
    }

    .aurum-input {
        width: 100%;
        padding: 14px 18px;
        background-color: var(--off-white);
        border: 1px solid #e2e2e2;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        outline: none;
    }

        .aurum-input:focus {
            background-color: white;
            border-color: var(--gold);
        }

    .input-focus-line {
        position: absolute;
        bottom: 0;
        left: 50%;
        width: 0;
        height: 2px;
        background: var(--gold);
        transition: all 0.4s ease;
        transform: translateX(-50%);
    }

    .aurum-input:focus + .input-focus-line {
        width: 100%;
    }

    /* ── Button ── */
    .btn-aurum-primary {
        background: linear-gradient(135deg, var(--maroon-dark), var(--maroon));
        color: var(--gold-pale);
        border: none;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        padding: 14px;
        transition: 0.3s;
    }

        .btn-aurum-primary:hover {
            filter: brightness(1.2);
            color: white;
            box-shadow: 0 5px 15px rgba(74, 15, 28, 0.2);
        }

    .italic {
        font-style: italic;
    }
</style>