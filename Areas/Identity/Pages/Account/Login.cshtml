@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<style>
    /* ── Auth Page Wrapper ── */
    .auth-wrapper {
        min-height: 75vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
    }

    .auth-container {
        width: 100%;
        max-width: 460px;
    }

    /* ── Brand Header ── */
    .auth-brand {
        text-align: center;
        margin-bottom: 2rem;
    }

    .auth-brand-ornament {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        margin-bottom: 8px;
    }

        .auth-brand-ornament::before,
        .auth-brand-ornament::after {
            content: '';
            display: block;
            height: 1px;
            width: 36px;
            background: linear-gradient(90deg, transparent, var(--gold));
        }

        .auth-brand-ornament::after {
            background: linear-gradient(90deg, var(--gold), transparent);
        }

    .auth-brand-diamond {
        color: var(--gold);
        font-size: 0.7rem;
    }

    .auth-brand-name {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--maroon-dark);
        letter-spacing: 0.06em;
        line-height: 1;
        margin: 0 0 4px;
    }

    .auth-brand-sub {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.58rem;
        font-weight: 600;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--gold);
    }

    /* ── Card ── */
    .auth-card {
        background: #fff;
        border: 1px solid rgba(201,168,76,0.18);
        border-top: 3px solid var(--gold);
        border-radius: 4px;
        padding: 2.2rem 2.4rem;
        box-shadow: 0 8px 40px rgba(74,15,28,0.1);
    }

    .auth-card-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--maroon);
        letter-spacing: 0.04em;
        margin-bottom: 0.3rem;
        text-align: center;
    }

    .auth-card-subtitle {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.68rem;
        color: #9A7070;
        text-align: center;
        margin-bottom: 1.8rem;
        letter-spacing: 0.06em;
    }

    .auth-divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(201,168,76,0.35), transparent);
        margin-bottom: 1.8rem;
    }

    /* ── Field ── */
    .aurum-field {
        margin-bottom: 1.2rem;
    }

    .aurum-label {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--text-mid);
        display: block;
        margin-bottom: 6px;
    }

    .aurum-input {
        background: var(--off-white);
        border: 1px solid rgba(107,26,42,0.16);
        border-radius: 2px;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.84rem;
        color: var(--text-dark);
        padding: 10px 14px;
        transition: border-color 0.2s, box-shadow 0.2s;
        width: 100%;
        display: block;
    }

        .aurum-input:focus {
            border-color: var(--gold);
            box-shadow: 0 0 0 3px rgba(201,168,76,0.15);
            outline: none;
            background: #fff;
        }

    .field-validation-error {
        font-size: 0.65rem;
        color: #c0392b;
        display: block;
        margin-top: 4px;
        letter-spacing: 0.04em;
    }

    .validation-summary-errors {
        font-size: 0.72rem;
        color: #c0392b;
        background: rgba(192,57,43,0.06);
        border: 1px solid rgba(192,57,43,0.18);
        border-left: 3px solid #c0392b;
        padding: 10px 14px;
        border-radius: 2px;
        margin-bottom: 1.2rem;
    }

    /* ── Remember Me ── */
    .aurum-check-label {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.72rem;
        color: var(--text-mid);
        cursor: pointer;
        margin-bottom: 1.4rem;
    }

    .aurum-check {
        width: 15px;
        height: 15px;
        accent-color: var(--maroon);
        cursor: pointer;
    }

    /* ── Submit Button ── */
    .btn-aurum-primary {
        background: linear-gradient(135deg, var(--maroon) 0%, var(--maroon-mid) 100%);
        color: var(--gold-light) !important;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        padding: 12px 28px;
        border: none;
        border-radius: 2px;
        width: 100%;
        box-shadow: 0 2px 14px rgba(74,15,28,0.28);
        transition: box-shadow 0.25s, transform 0.2s;
        cursor: pointer;
        display: block;
        text-align: center;
    }

        .btn-aurum-primary:hover {
            box-shadow: 0 5px 22px rgba(74,15,28,0.4);
            transform: translateY(-1px);
        }

    /* ── Footer links ── */
    .auth-links {
        margin-top: 1.6rem;
        padding-top: 1.2rem;
        border-top: 1px solid rgba(201,168,76,0.15);
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .auth-link {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.68rem;
        color: var(--maroon);
        text-decoration: none;
        letter-spacing: 0.06em;
        opacity: 0.7;
        transition: opacity 0.2s;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .auth-link::before {
            content: '›';
            color: var(--gold);
            font-size: 1rem;
            line-height: 1;
        }

        .auth-link:hover {
            opacity: 1;
            color: var(--maroon);
        }
</style>

<div class="auth-wrapper">
    <div class="auth-container">

        <!-- Brand Header -->
        <div class="auth-brand">
            <div class="auth-brand-ornament">
                <span class="auth-brand-diamond">◆</span>
            </div>
            <h1 class="auth-brand-name">Aurum Events</h1>
            <p class="auth-brand-sub">Luxury · Celebration · Legacy</p>
        </div>

        <!-- Card -->
        <div class="auth-card">
            <div class="auth-card-title">Welcome Back</div>
            <div class="auth-card-subtitle">Sign in to your account to continue</div>
            <div class="auth-divider"></div>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors" role="alert"></div>

                <div class="aurum-field">
                    <label asp-for="Input.Email" class="aurum-label">Email Address</label>
                    <input asp-for="Input.Email" class="aurum-input" autocomplete="username"
                           aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="field-validation-error"></span>
                </div>

                <div class="aurum-field">
                    <label asp-for="Input.Password" class="aurum-label">Password</label>
                    <input asp-for="Input.Password" class="aurum-input" autocomplete="current-password"
                           aria-required="true" placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="field-validation-error"></span>
                </div>

                <label class="aurum-check-label" asp-for="Input.RememberMe">
                    <input class="aurum-check" asp-for="Input.RememberMe" />
                    @Html.DisplayNameFor(m => m.Input.RememberMe)
                </label>

                <button id="login-submit" type="submit" class="btn-aurum-primary">
                    Sign In
                </button>

                <div class="auth-links">
                    <a id="forgot-password" asp-page="./ForgotPassword" class="auth-link">Forgot your password?</a>
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="auth-link">Create a new account</a>
                    <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="auth-link">Resend email confirmation</a>
                </div>
            </form>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
